[{"name":"app.R","content":"library(shiny)\r\nlibrary(tidyverse)\r\nlibrary(DT)\r\nlibrary(stringr)\r\nlibrary(htmltools)\r\n\r\nload(\"VQR24.RData\")\r\n\r\noptions(shiny.maxRequestSize = 100 * 1024^2)\r\n\r\n# =========================\r\n# Funzioni di supporto\r\n# =========================\r\n\r\npos_norm_100 <- function(pos, denom) {\r\n  case_when(\r\n    is.na(denom) ~ NA_real_,\r\n    denom == 1 ~ 1,\r\n    TRUE ~ floor((pos - 1) / (denom - 1) * 99) + 1\r\n  )\r\n}\r\n\r\ndt_style <- function(df, title = NULL) {\r\n  DT::datatable(\r\n    df,\r\n    rownames = FALSE,\r\n    class = \"compact stripe hover\",\r\n    filter = \"top\",\r\n    extensions = c(\"Buttons\", \"FixedHeader\"),\r\n    caption = if (!is.null(title)) tags$caption(\r\n      style = \"caption-side: top; text-align: left; font-weight: bold;\",\r\n      title\r\n    ),\r\n    options = list(\r\n      dom = \"Blrtip\",\r\n      buttons = c(\"copy\", \"csv\", \"excel\"),\r\n      scrollX = TRUE,\r\n      pageLength = 30,\r\n      lengthMenu = list(c(10, 30, 50, -1), c(\"10\", \"30\", \"50\", \"All\")),\r\n      autoWidth = TRUE,\r\n      orderClasses = TRUE,\r\n      fixedHeader = TRUE\r\n    ),\r\n    callback = JS(\"\r\n      setTimeout(function() {\r\n        table.columns.adjust().draw(false);\r\n      }, 100);\r\n    \")\r\n  ) %>%\r\n    formatStyle(\r\n      columns = \"R\",\r\n      backgroundColor = styleInterval(\r\n        c(0.8, 0.9, 0.99, 1.1),\r\n        c('red', 'orange', '#fff3b0', '#d9f2d9', '#2ca25f')\r\n      )\r\n    ) %>%\r\n    formatStyle(\r\n      columns = \"POS_NORM_100\",\r\n      backgroundColor = styleInterval(\r\n        c(25, 50, 75),\r\n        c('#2ca25f', '#a1d99b', '#fdae6b', '#de2d26')\r\n      ),\r\n      color = \"black\"\r\n    )\r\n}\r\n\r\nmake_dt <- function(df, title = NULL, id_col, r_col, pos_col, extra_first = NULL, extra_name = NULL) {\r\n  cols <- c(id_col, extra_first, r_col, pos_col)\r\n  cols <- cols[!is.na(cols) & cols != \"\"]\r\n  df2 <- df %>% dplyr::select(all_of(cols))\r\n  \r\n  names(df2)[names(df2) == id_col] <- \"Rank\"\r\n  names(df2)[names(df2) == r_col] <- \"R\"\r\n  names(df2)[names(df2) == pos_col] <- \"POS_NORM_100\"\r\n  \r\n  if (!is.null(extra_first) && extra_first != \"\" && !is.null(extra_name)) {\r\n    names(df2)[names(df2) == extra_first] <- extra_name\r\n  }\r\n  \r\n  dt_style(df2, title)\r\n}\r\n\r\nmake_dt_3 <- function(df, title = NULL, id_col, r_col, iras_col, pos_col, gev_col, extra_first = NULL) {\r\n  cols <- c(id_col, gev_col, extra_first, r_col, iras_col, pos_col)\r\n  cols <- cols[!is.na(cols) & cols != \"\"]\r\n  df2 <- df %>% dplyr::select(all_of(cols))\r\n  \r\n  names(df2)[names(df2) == id_col] <- \"Rank\"\r\n  names(df2)[names(df2) == r_col] <- \"R\"\r\n  names(df2)[names(df2) == iras_col] <- \"IRD\"\r\n  names(df2)[names(df2) == pos_col] <- \"POS_NORM_100\"\r\n  names(df2)[names(df2) == gev_col] <- \"GEV\"\r\n  \r\n  if (!is.null(extra_first) && extra_first != \"\") {\r\n    names(df2)[names(df2) == extra_first] <- \"Dipartimento\"\r\n  }\r\n  \r\n  dt_style(df2, title)\r\n}\r\n\r\nmake_dt_4 <- function(df, title = NULL, id_col, r_col, gsd_col, pos_col, extra_first = NULL) {\r\n  cols <- c(id_col, gsd_col, extra_first, r_col, pos_col)\r\n  cols <- cols[!is.na(cols) & cols != \"\"]\r\n  df2 <- df %>% dplyr::select(all_of(cols))\r\n  \r\n  names(df2)[names(df2) == id_col] <- \"Rank\"\r\n  names(df2)[names(df2) == r_col] <- \"R\"\r\n  names(df2)[names(df2) == gsd_col] <- \"GSD\"\r\n  names(df2)[names(df2) == pos_col] <- \"POS_NORM_100\"\r\n  \r\n  if (!is.null(extra_first) && extra_first != \"\") {\r\n    names(df2)[names(df2) == extra_first] <- \"Dipartimento\"\r\n  }\r\n  \r\n  dt_style(df2, title)\r\n}\r\n\r\n# =========================\r\n# Università disponibili\r\n# =========================\r\n\r\nuniversita_choices <- bound_by_sheet$`Tabella 3.3` %>%\r\n  distinct(Istituzione) %>%\r\n  arrange(Istituzione) %>%\r\n  pull(Istituzione)\r\n\r\n# =========================\r\n# UI\r\n# =========================\r\n\r\nui <- navbarPage(\r\n  title = \"VQR 2020-2024 Atenei\",\r\n  header = tagList(\r\n    tags$style(HTML(\"\r\n      body { font-size: 14px; }\r\n      table.dataTable tbody td { padding-top: 2px; padding-bottom: 2px; }\r\n      .selectize-input { min-height: 38px; }\r\n      .note-box {\r\n        background: #f8f9fa;\r\n        border-left: 4px solid #0d6efd;\r\n        padding: 12px 16px;\r\n        margin-bottom: 15px;\r\n        border-radius: 6px;\r\n      }\r\n      .footer {\r\n        margin-top: 20px;\r\n        padding: 14px 20px;\r\n        background: #f8f9fa;\r\n        border-top: 1px solid #dee2e6;\r\n        color: #444;\r\n        font-size: 13px;\r\n        text-align: center;\r\n        line-height: 1.5;\r\n      }\r\n      .footer a {\r\n        color: #0d6efd;\r\n        text-decoration: none;\r\n      }\r\n      .footer a:hover {\r\n        text-decoration: underline;\r\n      }\r\n      .dataTables_wrapper {\r\n        width: 100%;\r\n      }\r\n      table.dataTable {\r\n        width: 100% !important;\r\n      }\r\n      div.dataTables_scrollHeadInner,\r\n      div.dataTables_scrollHeadInner table {\r\n        width: 100% !important;\r\n      }\r\n    \"))\r\n  ),\r\n  \r\n  tabPanel(\r\n    \"Area GEV\",\r\n    sidebarLayout(\r\n      sidebarPanel(\r\n        width = 3,\r\n        selectInput(\"uni\", \"Seleziona università\", choices = universita_choices),\r\n        div(class = \"note-box\",\r\n            HTML(\"<b>Note<\/b><br/>\r\n                 - R più è verde se &gt; 1, più è arancio se ≤ 1.<br/>\r\n                 - POS_NORM_100: 1 = migliori posizioni, 100 = peggiori.<br/>\r\n                 - Filtri nelle intestazioni e download CSV/Excel disponibili.\")\r\n        )\r\n      ),\r\n      mainPanel(\r\n        tabsetPanel(\r\n          tabPanel(\"Tab. 3.3 a+b\", DTOutput(\"tab33\")),\r\n          tabPanel(\"Tab. 3.1 a\", DTOutput(\"tab31\")),\r\n          tabPanel(\"Tab. 3.2 b\", DTOutput(\"tab32\"))\r\n        )\r\n      )\r\n    )\r\n  ),\r\n  \r\n  tabPanel(\r\n    \"GSD Ateneo\",\r\n    sidebarLayout(\r\n      sidebarPanel(width = 3, h4(textOutput(\"uni_label_1\"))),\r\n      mainPanel(\r\n        tabsetPanel(\r\n          tabPanel(\"Tab. 3.6 a+b\", DTOutput(\"tab36\")),\r\n          tabPanel(\"Tab. 3.4 a\", DTOutput(\"tab34\")),\r\n          tabPanel(\"Tab. 3.5 b\", DTOutput(\"tab35\"))\r\n        )\r\n      )\r\n    )\r\n  ),\r\n  \r\n  tabPanel(\r\n    \"SSD Ateneo\",\r\n    sidebarLayout(\r\n      sidebarPanel(width = 3, h4(textOutput(\"uni_label_2\"))),\r\n      mainPanel(\r\n        tabsetPanel(\r\n          tabPanel(\"Tab. 3.9 a+b\", DTOutput(\"tab39\")),\r\n          tabPanel(\"Tab. 3.7 a\", DTOutput(\"tab37\")),\r\n          tabPanel(\"Tab. 3.8 b\", DTOutput(\"tab38\"))\r\n        )\r\n      )\r\n    )\r\n  ),\r\n  \r\n  tabPanel(\r\n    \"Dipartimenti\",\r\n    sidebarLayout(\r\n      sidebarPanel(width = 3, h4(textOutput(\"uni_label_3\"))),\r\n      mainPanel(\r\n        tabsetPanel(\r\n          tabPanel(\"Tab. 4.3 a+b\", DTOutput(\"tab43\")),\r\n          tabPanel(\"Tab. 4.1 a\", DTOutput(\"tab41\")),\r\n          tabPanel(\"Tab. 4.2 b\", DTOutput(\"tab42\"))\r\n        )\r\n      )\r\n    )\r\n  ),\r\n  \r\n  tabPanel(\r\n    \"Dipartimenti e GSD\",\r\n    sidebarLayout(\r\n      sidebarPanel(width = 3, h4(textOutput(\"uni_label_4\"))),\r\n      mainPanel(\r\n        tabsetPanel(\r\n          tabPanel(\"Tab. 4.6 a+b\", DTOutput(\"tab46\")),\r\n          tabPanel(\"Tab. 4.4 a\", DTOutput(\"tab44\")),\r\n          tabPanel(\"Tab. 4.5 b\", DTOutput(\"tab45\"))\r\n        )\r\n      )\r\n    )\r\n  ),\r\n  \r\n  footer = tags$footer(\r\n    class = \"footer\",\r\n    tags$div(\r\n      style = \"max-width: 1200px; margin: 0 auto;\",\r\n      HTML(\"A. Irpino - DMF - Unicampania \"),\r\n      tags$a(\r\n        href = \"mailto:antonio.irpino@unicampania.it\",\r\n        \"antonio.irpino@unicampania.it\"\r\n      ),\r\n      HTML(\" &nbsp;|&nbsp; Elaborazioni su dati VQR 2024 pubblicati qui: \"),\r\n      tags$a(\r\n        href = \"https://www.anvur.it/it/ricerca/qualita-della-ricerca/rapporti-di-valutazione/vqr-2020-2024\",\r\n        target = \"_blank\",\r\n        rel = \"noopener noreferrer\",\r\n        \"AVA 2024 data\"\r\n      )\r\n    )\r\n  )\r\n)\r\n\r\n# =========================\r\n# SERVER\r\n# =========================\r\n\r\nserver <- function(input, output, session) {\r\n  \r\n  dati_uni <- reactive({\r\n    req(input$uni)\r\n    list(\r\n      t33 = bound_by_sheet$`Tabella 3.3` %>% filter(Istituzione == input$uni),\r\n      t31 = bound_by_sheet$`Tabella 3.1` %>% filter(Istituzione == input$uni),\r\n      t32 = bound_by_sheet$`Tabella 3.2` %>% filter(Istituzione == input$uni),\r\n      t36 = bound_by_sheet$`Tabella 3.6` %>% filter(Istituzione == input$uni),\r\n      t34 = bound_by_sheet$`Tabella 3.4` %>% filter(Istituzione == input$uni),\r\n      t35 = bound_by_sheet$`Tabella 3.5` %>% filter(Istituzione == input$uni),\r\n      t39 = bound_by_sheet$`Tabella 3.9` %>% filter(Istituzione == input$uni),\r\n      t37 = bound_by_sheet$`Tabella 3.7` %>% filter(Istituzione == input$uni),\r\n      t38 = bound_by_sheet$`Tabella 3.8` %>% filter(Istituzione == input$uni),\r\n      t43 = bound_by_sheet$`Tabella 4.3` %>% filter(Istituzione == input$uni),\r\n      t41 = bound_by_sheet$`Tabella 4.1` %>% filter(Istituzione == input$uni),\r\n      t42 = bound_by_sheet$`Tabella 4.2` %>% filter(Istituzione == input$uni),\r\n      t46 = bound_by_sheet$`Tabella 4.6` %>% filter(Istituzione == input$uni),\r\n      t44 = bound_by_sheet$`Tabella 4.4` %>% filter(Istituzione == input$uni),\r\n      t45 = bound_by_sheet$`Tabella 4.5` %>% filter(Istituzione == input$uni)\r\n    )\r\n  })\r\n  \r\n  output$uni_label_1 <- renderText(input$uni)\r\n  output$uni_label_2 <- renderText(input$uni)\r\n  output$uni_label_3 <- renderText(input$uni)\r\n  output$uni_label_4 <- renderText(input$uni)\r\n  \r\n  output$tab33 <- renderDT({\r\n    tab33 <- dati_uni()$t33 %>%\r\n      mutate(\r\n        source_file = str_remove(source_file, \"GEV\"),\r\n        R = `R (profilo a+b)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\")\r\n      ) %>%\r\n      transmute(Rank, GEV = source_file, R, IRAS = IRAS1_2x100, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt(tab33, \"Tabella 3.3 - Profilo a+b\", \"Rank\", \"R\", \"POS_NORM_100\", \"GEV\", \"GEV\")\r\n  })\r\n  \r\n  output$tab31 <- renderDT({\r\n    tab31 <- dati_uni()$t31 %>%\r\n      mutate(\r\n        source_file = str_remove(source_file, \"GEV\"),\r\n        R = `R (profilo a)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\")\r\n      ) %>%\r\n      transmute(Rank, GEV = source_file, R, IRAS = IRAS1x100, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt(tab31, \"Tabella 3.1 - Profilo a\", \"Rank\", \"R\", \"POS_NORM_100\", \"GEV\", \"GEV\")\r\n  })\r\n  \r\n  output$tab32 <- renderDT({\r\n    tab32 <- dati_uni()$t32 %>%\r\n      mutate(\r\n        source_file = str_remove(source_file, \"GEV\"),\r\n        R = `R (profilo b)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\")\r\n      ) %>%\r\n      transmute(Rank, GEV = source_file, R, IRAS = IRAS2x100, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt(tab32, \"Tabella 3.2 - Profilo b\", \"Rank\", \"R\", \"POS_NORM_100\", \"GEV\", \"GEV\")\r\n  })\r\n  \r\n  output$tab36 <- renderDT({\r\n    tab36 <- dati_uni()$t36 %>%\r\n      mutate(\r\n        R = `R (profilo a+b)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\")\r\n      ) %>%\r\n      transmute(Rank, GSD = GSD_ric, R, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt(tab36, \"Tabella 3.6 - GSD profilo a+b\", \"Rank\", \"R\", \"POS_NORM_100\", \"GSD\", \"GSD\")\r\n  })\r\n  \r\n  output$tab34 <- renderDT({\r\n    tab34 <- dati_uni()$t34 %>%\r\n      mutate(\r\n        R = `R (profilo a)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\")\r\n      ) %>%\r\n      transmute(Rank, GSD = GSD_ric, R, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt(tab34, \"Tabella 3.4 - GSD profilo a\", \"Rank\", \"R\", \"POS_NORM_100\", \"GSD\", \"GSD\")\r\n  })\r\n  \r\n  output$tab35 <- renderDT({\r\n    tab35 <- dati_uni()$t35 %>%\r\n      mutate(\r\n        R = `R (profilo b)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\")\r\n      ) %>%\r\n      transmute(Rank, GSD = GSD_ric, R, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt(tab35, \"Tabella 3.5 - GSD profilo b\", \"Rank\", \"R\", \"POS_NORM_100\", \"GSD\", \"GSD\")\r\n  })\r\n  \r\n  output$tab39 <- renderDT({\r\n    tab39 <- dati_uni()$t39 %>%\r\n      mutate(\r\n        R = `R (profilo a+b)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\")\r\n      ) %>%\r\n      transmute(Rank, SSD = SSD_ric, R, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt(tab39, \"Tabella 3.9 - SSD profilo a+b\", \"Rank\", \"R\", \"POS_NORM_100\", \"SSD\", \"SSD\")\r\n  })\r\n  \r\n  output$tab37 <- renderDT({\r\n    tab37 <- dati_uni()$t37 %>%\r\n      mutate(\r\n        R = `R (profilo a)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\")\r\n      ) %>%\r\n      transmute(Rank, SSD = SSD_ric, R, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt(tab37, \"Tabella 3.7 - SSD profilo a\", \"Rank\", \"R\", \"POS_NORM_100\", \"SSD\", \"SSD\")\r\n  })\r\n  \r\n  output$tab38 <- renderDT({\r\n    tab38 <- dati_uni()$t38 %>%\r\n      mutate(\r\n        R = `R (profilo b)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\")\r\n      ) %>%\r\n      transmute(Rank, SSD = SSD_ric, R, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt(tab38, \"Tabella 3.8 - SSD profilo b\", \"Rank\", \"R\", \"POS_NORM_100\", \"SSD\", \"SSD\")\r\n  })\r\n  \r\n  output$tab43 <- renderDT({\r\n    tab43 <- dati_uni()$t43 %>%\r\n      mutate(\r\n        source_file = str_remove(source_file, \"GEV\"),\r\n        R = `R (profilo a+b)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. dipartimenti compl.`),\r\n        Rank = rank(-R, ties.method = \"min\"),\r\n        IRD = IRD1_2x100,\r\n        GEV = source_file\r\n      ) %>%\r\n      transmute(Rank, GEV, Dipartimento, R, IRD, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt_3(tab43, \"Tabella 4.3 - a+b\", \"Rank\", \"R\", \"IRD\", \"POS_NORM_100\", \"GEV\", \"Dipartimento\")\r\n  })\r\n  \r\n  output$tab41 <- renderDT({\r\n    tab41 <- dati_uni()$t41 %>%\r\n      mutate(\r\n        source_file = str_remove(source_file, \"GEV\"),\r\n        R = `R (profilo a)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\"),\r\n        IRD = IRD1x100,\r\n        GEV = source_file\r\n      ) %>%\r\n      transmute(Rank, GEV, Dipartimento, R, IRD, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt_3(tab41, \"Tabella 4.1 - a\", \"Rank\", \"R\", \"IRD\", \"POS_NORM_100\", \"GEV\", \"Dipartimento\")\r\n  })\r\n  \r\n  output$tab42 <- renderDT({\r\n    tab42 <- dati_uni()$t42 %>%\r\n      mutate(\r\n        source_file = str_remove(source_file, \"GEV\"),\r\n        R = `R (profilo b)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. istituzioni compl.`),\r\n        Rank = rank(-R, ties.method = \"min\"),\r\n        IRD = IRD2x100,\r\n        GEV = source_file\r\n      ) %>%\r\n      transmute(Rank, GEV, Dipartimento, R, IRD, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt_3(tab42, \"Tabella 4.2 - b\", \"Rank\", \"R\", \"IRD\", \"POS_NORM_100\", \"GEV\", \"Dipartimento\")\r\n  })\r\n  \r\n  output$tab46 <- renderDT({\r\n    tab46 <- dati_uni()$t46 %>%\r\n      mutate(\r\n        R = `R (profilo a+b)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. dipartimenti compl.`),\r\n        Rank = rank(-R, ties.method = \"min\"),\r\n        GSD = GSD_ric\r\n      ) %>%\r\n      transmute(Rank, GSD, Dipartimento, R, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt_4(tab46, \"Tabella 4.6 - a+b\", \"Rank\", \"R\", \"GSD\", \"POS_NORM_100\", \"Dipartimento\")\r\n  })\r\n  \r\n  output$tab44 <- renderDT({\r\n    tab44 <- dati_uni()$t44 %>%\r\n      mutate(\r\n        R = `R (profilo a)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. dipartimenti compl.`),\r\n        Rank = rank(-R, ties.method = \"min\"),\r\n        GSD = GSD_ric\r\n      ) %>%\r\n      transmute(Rank, GSD, Dipartimento, R, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt_4(tab44, \"Tabella 4.4 - a\", \"Rank\", \"R\", \"GSD\", \"POS_NORM_100\", \"Dipartimento\")\r\n  })\r\n  \r\n  output$tab45 <- renderDT({\r\n    tab45 <- dati_uni()$t45 %>%\r\n      mutate(\r\n        R = `R (profilo b)`,\r\n        POS_NORM_100 = pos_norm_100(`Pos. grad. compl.`, `Num. dipartimenti compl.`),\r\n        Rank = rank(-R, ties.method = \"min\"),\r\n        GSD = GSD_ric\r\n      ) %>%\r\n      transmute(Rank, GSD, Dipartimento, R, POS_NORM_100) %>%\r\n      arrange(Rank)\r\n    \r\n    make_dt_4(tab45, \"Tabella 4.5 - b\", \"Rank\", \"R\", \"GSD\", \"POS_NORM_100\", \"Dipartimento\")\r\n  })\r\n}\r\n\r\nshinyApp(